*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{

font-family:Arial, Helvetica, sans-serif;
background:linear-gradient(135deg,#eef2f7,#dce3f0);
min-height:100vh;
display:flex;
justify-content:center;

}

.container{

width:95%;
max-width:1400px;
margin-top:30px;
text-align:center;

}

h1{

font-size:32px;
margin-bottom:20px;
color:#333;

}

form{

margin-bottom:30px;

}

input[type=file]{

padding:8px;

}

button{

padding:10px 20px;
border:none;
border-radius:6px;
background:#2f80ed;
color:white;
cursor:pointer;
font-size:15px;
margin-left:10px;
transition:0.3s;

}

button:hover{

background:#1366d6;

}

.images{

display:grid;
grid-template-columns: repeat(auto-fit, minmax(260px,1fr));
gap:25px;
margin-top:20px;

}

.image-box{

background:white;
padding:15px;
border-radius:12px;
box-shadow:0 6px 18px rgba(0,0,0,0.1);
transition:0.25s;

}

.image-box:hover{

transform:translateY(-5px);
box-shadow:0 10px 25px rgba(0,0,0,0.15);

}

.image-box h3{

margin-bottom:10px;
font-size:18px;
color:#444;

}

.image-box img{

width:100%;
height:auto;
border-radius:8px;

}

table{

margin:40px auto;
border-collapse:collapse;
min-width:350px;
background:white;
box-shadow:0 6px 18px rgba(0,0,0,0.1);
border-radius:10px;
overflow:hidden;

}

th{

background:#2f80ed;
color:white;
padding:12px;

}

td{

padding:10px;
border-top:1px solid #eee;

}

tr:hover{

background:#f5f7fb;

}

@media (max-width:768px){

h1{
font-size:24px;
}

.image-box h3{
font-size:16px;
}

}